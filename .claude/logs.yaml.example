# 远程日志查询配置
#
# log-query.py 读这个文件拿 target 列表 + SSH 信息 + 日志路径。
# 拷成 .claude/logs.yaml 后改成你的真实 target，或跑：
#   python3 .claude/scripts/log-query.py --add
# 交互式新增。
#
# 字段：
#   host:           必填，服务器 IP 或 hostname
#   user:           必填，远端用户名
#   password_env:   必填，密码所在 env var 名（不是密码本身！）
#   port:           可选，SSH 端口（默认 22）
#   paths:          必填，日志文件路径列表（支持 glob，至少 1 个）
#   default_grep_v: 可选，默认排除的噪音 pattern 列表（grep -v）
#
# 安全说明：
#   - 密码绝不进 logs.yaml；只存 env var 名字
#   - 实际密码在 ~/.zshrc：export ORDER_SVC_SSH_PWD="..."
#   - log-query.py 只构造 read-only 命令（tail / grep / cat / zcat / ls）
#   - 文件可以 commit 到 Git（团队共享 target 名 + 服务器地址 + 日志路径）
#
# 鉴权：username + password，paramiko 直连内网 IP（参考项目里的 login_consum.py）

targets:
  # ─── 示例 1：marketing 单服务器 ────────────────────────────────────
  prod-marketing:
    host: 10.0.5.10
    user: dev
    password_env: PROD_MARKETING_PWD
    paths:
      - /app/webapps/logs/chatlabs-marketing-platform-single.*.log
    default_grep_v:
      - "DEBUG"
      - "/health"

  # ─── 示例 2：multi-app 集群里某一台（不同密码）─────────────────────
  prod-multi-app1:
    host: 10.0.5.20
    user: dev
    password_env: PROD_MULTI_PWD            # 多台 multi-app 可以共用同一个 env var
    paths:
      - /app/webapps/app1/logs/*.log

  prod-multi-app2:
    host: 10.0.5.21
    user: dev
    password_env: PROD_MULTI_PWD            # 同上，复用同一密码
    paths:
      - /app/webapps/app2/logs/*.log

  # ─── 示例 3：MySQL 慢查询 / error 日志 ──────────────────────────────
  prod-mysql:
    host: 10.0.5.30
    user: dba
    password_env: PROD_MYSQL_SSH_PWD
    paths:
      - /var/log/mysql/slow.log
      - /var/log/mysql/error.log

  # ─── 示例 4：测试环境（端口非默认 22）──────────────────────────────
  staging-app:
    host: staging.internal
    user: deploy
    password_env: STAGING_APP_SSH_PWD
    port: 2222
    paths:
      - /var/log/app/*.log
