{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__mysql-.*|mcp__mongo-.*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/db-readonly-guard.py"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/evaluator-context-guard.py"
          }
        ]
      }
    ]
  }
}
